# GATIE — Environment variables
# Copy to .env and adjust values for your deployment.
# humacli maps CLI flags to env vars with the SERVICE_ prefix.

# Server
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8888

# PostgreSQL
SERVICE_DATABASE_URL=postgres://gatie:gatie@localhost:5432/gatie?sslmode=disable

# Valkey (Redis-compatible)
SERVICE_VALKEY_URL=valkey://localhost:6379

# JWT signing secret — CHANGE THIS in production.
# If left empty the server auto-generates one on each restart
# (all existing sessions will be invalidated).
SERVICE_JWT_SECRET=
